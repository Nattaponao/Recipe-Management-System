generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             Int          @id @default(autoincrement())
  email          String       @unique
  name           String?
  passwordHashed String?      @map("password_hashed")
  role           String       @default("USER")
  lastSeen       DateTime?    @db.Timestamptz(6)
  image          String?
  posts          Post[]
  recipeLikes    RecipeLike[]
  recipeSaves    RecipeSave[]
  recipes        Recipe[]

  @@map("User")
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String?
  published Boolean @default(false)
  authorId  Int
  author    User    @relation(fields: [authorId], references: [id])
}

model Recipe {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  name          String?            @default("")
  description   String?
  coverImage    String?            @map("cover_image")
  category      String?
  country       String?
  tags          String?
  authorId      Int?               @map("author_id")
  featuredCards FeaturedCard[]
  popularCards  PopularCard[]
  ingredients   RecipeIngredient[]
  recipeLikes   RecipeLike[]
  recipeSaves   RecipeSave[]
  steps         RecipeStep[]
  author        User?              @relation(fields: [authorId], references: [id])

  @@map("recipes")
}

model RecipeIngredient {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipeId  String?  @default(dbgenerated("gen_random_uuid()")) @map("recipe_id") @db.Uuid
  name      String?
  amount    Decimal? @db.Decimal
  unit      String?
  sortOrder BigInt?  @map("sort_order")
  recipe    Recipe?  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_ingredients")
}

model RecipeStep {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipeId String? @default(dbgenerated("gen_random_uuid()")) @map("recipe_id") @db.Uuid
  stepNo   BigInt? @map("step_no")
  text     String?
  recipe   Recipe? @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_steps")
}

model RecipeLike {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    Int      @map("user_id")
  recipeId  String   @map("recipe_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, recipeId], map: "recipe_likes_user_recipe_unique")
  @@map("recipe_likes")
}

model RecipeSave {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    Int      @map("user_id")
  recipeId  String   @map("recipe_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, recipeId], map: "recipe_saves_user_recipe_unique")
  @@map("recipe_saves")
}

model FeaturedCard {
  id            Int      @id @default(autoincrement())
  slot          Int      @unique
  recipeId      String   @map("recipe_id") @db.Uuid
  profileName   String?  @map("profile_name")
  profileDate   String?  @map("profile_date")
  profileAvatar String?  @map("profile_avatar")
  updatedAt     DateTime @updatedAt @map("updated_at")
  recipe        Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("featured_cards")
}

model PopularCard {
  id        Int      @id @default(autoincrement())
  slot      Int      @unique
  recipeId  String   @map("recipe_id") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("popular_cards")
}

model HeroSetting {
  id            Int      @id @default(1)
  title1        String   @default("Pad Krapao")
  title2        String   @default("Moo sub")
  tag1          String   @default("How to")
  tag2          String   @default("Baking")
  readTime      String   @default("12 min read") @map("read_time")
  ctaText       String   @default("READ NOW") @map("cta_text")
  rightImageUrl String?  @map("right_image_url")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("hero_settings")
}

model AiCache {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ingredientsKey String   @unique @map("ingredients_key")
  resultJson     Json     @map("result_json")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("ai_cache")
}
